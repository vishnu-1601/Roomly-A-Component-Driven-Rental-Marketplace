<%- layout("/layouts/boilerplate.ejs") %>
<div class="show-page">
    <div class="col-8 offset-3">
        <h3><b><i><%=listing.title%></i></b></h3>
    </div>
    <div class="card col-6 offset-3 show-card listing-card">
        <img src="<%=listing.image.url%>" alt="listing_image" class="card-img-top show-img">
        <div class="card-body">
            <div class="card-text">
                <%=listing.description%> <br>
                <%=(listing.price ?? 0).toLocaleString("en-IN")%> <br>
                <%=listing.location%> <br>
                <%=listing.country%>
                <div class="show-btn mt-2">
                    <form action="/listings/<%=listing._id%>/edit" method="get">
                        <button class="btn btn-info">edit</button>
                    </form>
                    <form action="/listings/<%=listing._id%>?_method=delete" method="post">
                        <button class="btn btn-danger">delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <div class="col-8 offset-3">
        <hr>
        <h4>Leave a Review</h4>
        <form action="/listings/<%=listing._id%>/reviews" method="post" novalidate class="needs-validation">
            <div class="mt-3 mb-3">
                <label class="form-label">Rating</label>
                <div class="mb-3" id="star-rating" style="display: flex; gap: 8px; font-size: 32px; cursor: pointer;">
                    <span class="star" data-value="1" style="color: #dee2e6;">★</span>
                    <span class="star" data-value="2" style="color: #dee2e6;">★</span>
                    <span class="star" data-value="3" style="color: #dee2e6;">★</span>
                    <span class="star" data-value="4" style="color: #dee2e6;">★</span>
                    <span class="star" data-value="5" style="color: #dee2e6;">★</span>
                </div>
                <input type="hidden" name="review[rating]" id="rating-value" value="">
            </div>
            <div class="mt-3 mb-3">
                <label for="comment" class="form-label">Comments</label>
                <textarea name="review[comment]" id="comment" rows="5" class="form-control" required></textarea>
                <div class="invalid-feedback">
                    Please enter a comment.
                </div>
            </div>
            <div class="show-btn">
                <button class="btn btn-outline-success">submit</button>
            </div>
        </form>
        <hr>
        <div style="margin-top: 2rem;">
            <h4 style="font-weight: 500; margin-bottom: 1rem;">
                All reviews
            <span style="font-size: 14px; font-weight: 400; color: gray; margin-left: 8px;">
                <%= listing.reviews.length %> reviews
            </span>
            </h4>
            <div class="row">
                <% for (let review of listing.reviews) { %>
                <div class="card mb-3 " class="card mb-3" style="background-color: transparent !important; border: none;">
                    <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <div style="width:36px; height:36px; border-radius:50%; background:#e6f1fb;
                                    display:flex; align-items:center; justify-content:center;
                                    font-size:13px; font-weight:500; color:#185fa5;">
                        😎
                        </div>
                        <div>
                        <p class="mb-0" style="font-size:14px; font-weight:500;">Anonymous</p>
                        <p class="mb-0 text-muted" style="font-size:12px;">
                            <%= review.created_at.toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
                        </p>
                        </div>
                        <div class="ms-auto" style="color: #BA7517; font-size: 15px;">
                        <% for(let i = 1; i <= 5; i++) { %>
                            <%= i <= review.rating ? "★" : "☆" %>
                        <% } %>
                        </div>
                    </div>
                    <p class="mb-0 text-muted" style="font-size:14px; line-height:1.6;">
                        <%= review.comment %>
                    </p>

                    </div>
                </div>
                <% } %>
                </div>
        </div>
    </div>
</div>
<script>
  const stars = document.querySelectorAll('#star-rating .star');
  const ratingInput = document.getElementById('rating-value');

  stars.forEach(star => {
    star.addEventListener('mouseover', function () {
      stars.forEach(s => {
        s.style.color = s.dataset.value <= this.dataset.value ? '#BA7517' : '#dee2e6';
      });
    });

    star.addEventListener('mouseout', function () {
      const selected = ratingInput.value;
      stars.forEach(s => {
        s.style.color = s.dataset.value <= selected ? '#BA7517' : '#dee2e6';
      });
    });

    star.addEventListener('click', function () {
      ratingInput.value = this.dataset.value;
      stars.forEach(s => {
        s.style.color = s.dataset.value <= this.dataset.value ? '#BA7517' : '#dee2e6';
      });
    });
  });
</script>